{
  "name": "woo-monitor",
  "version": "3.1.0",
  "description": "WooCommerce Monitoring Server",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "build": "echo 'No dashboard build needed for deployment'",
    "migrate": "node src/migrate-from-json.js"
  },
  "keywords": [
    "woocommerce",
    "monitoring",
    "alerts"
  ],
  "author": "Ashbi",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@woocommerce/woocommerce-rest-api": "^1.0.2",
    "axios": "^1.7.9",
    "better-sqlite3": "^12.6.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "node-cron": "^3.0.3",
    "p-limit": "^3.1.0"
  }
}
