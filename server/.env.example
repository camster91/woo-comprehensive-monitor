# -----------------------------
# WooCommerce Monitor ENV Variables
# -----------------------------

# Server Port
PORT=3000

# Mailgun API Configuration
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=ashbi.ca

# From address for alert emails (optional, defaults to alerts@MAILGUN_DOMAIN)
MAIL_FROM=WooMonitor Alert <alerts@ashbi.ca>

# Where you want the alerts sent TO
ALERT_EMAIL=cameron@ashbi.ca

# API Key for protected endpoints (required for /api/dashboard/*, /api/stores/*, /api/reload-sites)
API_KEY=your_api_key_here
